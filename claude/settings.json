    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(> /dev/sda*)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      { "matcher": "startup", "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/git_session_check.sh" } ] },
      { "matcher": "resume",  "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/git_session_check.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/auto_push_after_commit.sh" } ] },
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/deploy_verifier.py", "timeout": 45 } ] },
      { "matcher": "Edit|Write",  "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/post-edit-format.sh" } ] },
      { "matcher": "Edit|Write",  "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/post-edit-typecheck.sh", "timeout": 30 } ] },
      { "matcher": "Edit|Write",  "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/post-edit-console-warn.sh" } ] }
    ],
    "PreCompact": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/pre-compact-save.sh" } ] },
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/pre-compact-bookkeeper.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "python3 __HOME__/scripts/bash_command_validator.py" } ] },
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/destructive_blocker.py" } ] },
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/bash_as_read_blocker.py" } ] },
      { "matcher": "Agent|Task",  "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/trivial_subagent_blocker.py" } ] },
      { "matcher": "*",           "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/compact_watchdog.py" } ] },
      { "matcher": "Grep|Glob",   "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/pre-search-memory-redirect.sh" } ] }
    ],
    "Stop": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "bash __HOME__/scripts/hooks/stop-console-log-check.sh" } ] },
      { "matcher": "*", "hooks": [ { "type": "command", "command": "python3 __HOME__/.claude/hooks/bookkeeper_enforcer.py" } ] }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); user=$(whoami); cwd=$(echo \"$input\" | python3 -c \"import sys,json; print(json.load(sys.stdin)['workspace']['current_dir'])\" 2>/dev/null | sed \"s|$HOME|~|g\"); model=$(echo \"$input\" | python3 -c \"import sys,json; print(json.load(sys.stdin)['model']['display_name'])\" 2>/dev/null); time=$(date +%H:%M); remaining=$(echo \"$input\" | python3 -c \"import sys,json; print(json.load(sys.stdin)['context_window']['remaining_percentage'])\" 2>/dev/null); cd \"$(echo \"$input\" | python3 -c \"import sys,json; print(json.load(sys.stdin)['workspace']['current_dir'])\" 2>/dev/null)\" 2>/dev/null; branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo ''); status=''; [ -n \"$branch\" ] && { [ -n \"$(git status --porcelain 2>/dev/null)\" ] && status='*'; }; B='\\033[38;2;30;102;245m'; G='\\033[38;2;64;160;43m'; Y='\\033[38;2;223;142;29m'; M='\\033[38;2;136;57;239m'; C='\\033[38;2;23;146;153m'; R='\\033[0m'; T='\\033[38;2;76;79;105m'; printf \"${C}${user}${R}:${B}${cwd}${R}\"; [ -n \"$branch\" ] && printf \" ${G}${branch}${Y}${status}${R}\"; [ -n \"$remaining\" ] && printf \" ${M}ctx:${remaining}%%${R}\"; printf \" ${T}${model}${R} ${Y}${time}${R}\"; echo"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "swift-lsp@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true,
    "vercel@claude-plugins-official": true,
    "linear@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "_comment_personal_assistant": "Optional. Connects to a personal Heroku-hosted FastAPI assistant. Delete this block if you don't have one. PA_API_TOKEN must be your own service token.",
    "personal-assistant": {
      "command": "/opt/homebrew/bin/python3",
      "args": [
        "__HOME__/.claude/mcp/personal_assistant_mcp.py"
      ],
      "env": {
        "PA_API_URL": "https://your-personal-assistant.example.com",
        "PA_API_TOKEN": "REPLACE_WITH_YOUR_OWN_TOKEN"
      }
    }
  }
}
